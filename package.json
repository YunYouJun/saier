{
  "name": "saier-monorepo",
  "type": "module",
  "version": "0.1.6-beta.1",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "description": "Elegant online painting runtime powered by PixiJS",
  "author": {
    "email": "me@yunyoujun.cn",
    "name": "YunYouJun",
    "url": "https://yunyoujun.cn"
  },
  "license": "MPL-2.0",
  "keywords": [],
  "scripts": {
    "build": "pnpm build:lib && pnpm build:site",
    "generate": "pnpm -C site run generate",
    "build:react": "pnpm -C examples/react run build",
    "build:vue": "pnpm -C examples/vue run build",
    "build:lib": "pnpm -C packages/saier run build",
    "build:site": "pnpm -C site run build",
    "generate:site": "pnpm -C site run generate",
    "dev": "pnpm -C site run dev",
    "dev:site": "pnpm -C site run dev",
    "dev:vue": "pnpm -C examples/vue run dev",
    "docs:dev": "pnpm -C docs run docs:dev",
    "docs:build": "pnpm -C docs run docs:build",
    "docs:preview": "pnpm -C docs run docs:preview",
    "lint": "eslint .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "pack:check": "CI=true pnpm --dir packages/core pack --dry-run && CI=true pnpm --dir packages/pixi pack --dry-run && CI=true pnpm --dir packages/saier pack --dry-run && CI=true pnpm --dir packages/vue pack --dry-run",
    "publish:beta:dry": "pnpm -r --filter @saier/core --filter @saier/pixi --filter saier --filter @saier/vue publish --dry-run --access public --tag beta --no-git-checks",
    "publish:beta": "pnpm -r --filter @saier/core --filter @saier/pixi --filter saier --filter @saier/vue publish --access public --tag beta --no-git-checks",
    "release": "bumpp",
    "release:beta": "bumpp --preid beta && pnpm run publish:beta"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@playwright/test": "^1.61.1",
    "@vitest/browser-playwright": "4.1.9",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unocss": "^66.7.2",
    "vitest": "^4.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix --no-warn-ignored"
  }
}
